BOT_TOKEN=ganti_dengan_token_dari_botfather
ALLOWED_CHAT_ID=-1001234567890
ADMIN_IDS=123456789,987654321

# Contact username (tanpa @) yang ditampilin ke non-admin saat mereka coba DM bot.
# Default: hokisetahun. Ganti ke handle Telegram lu sendiri.
CONTACT_USERNAME=hokisetahun

# BotUsername (tanpa @) untuk deep-link "Setup di DM →" dari group.
# Boleh kosong — bot akan auto-detect via getMe() pas startup.
BOT_USERNAME=

# CF email & API key bisa di-set lewat bot juga (menu Settings)
# Kalau di-set di sini, akan jadi default sampai user override via bot
CF_EMAIL=
CF_API_KEY=

# Interval cek nawala (default 45s). Format: 30s, 1m, 2m30s
CHECK_INTERVAL=45s

# ─── Optional API Keys untuk checker (lebih banyak quota / triple-source) ───
#
# Source 2: TrustPositif API v1 — premium tier
# Daftar gratis di https://trust-positif.gitbook.io/docs
# Format: tp_xxxxx
# Kosongin = pakai freemium 100/hari per IP
TRUSTPOSITIF_API_KEY=

# Source 3: NawalaCheck.com — paid service (jadi triple-source check)
# Subscribe di https://nawalacheck.com
# Format: API key dari dashboard mereka
# Kosongin = pakai dual-source (Rest_server + API v1) aja
NAWALACHECK_API_KEY=

# ─── Optional: KLIKCEPAT (66biolinks) Integration ─────────────────────────
# Bot bisa CRUD link/project + auto-swap location_url ketika domain blocked
# Setup: enable API di plan klikcepat → normal admin generate API key
# Atau set via menu Settings → 🔗 Klikcepat di bot
KLIKCEPAT_BASE_URL=
KLIKCEPAT_API_KEY=

# Custom display domain (untuk display URL link di bot)
# Misal lu pakai custom domain "thymeband.com" yang di-share dari MASTER account
# (sub-user API gak bisa see domain list — set manual di sini).
# Contoh: thymeband.com  (tanpa https://, tanpa trailing slash)
# Kosongin = pakai klikcepat.com default
KLIKCEPAT_DISPLAY_DOMAIN=
